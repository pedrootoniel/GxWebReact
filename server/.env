# ===========================================
# GxWebReact - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# -------------------------------------------
# Frontend (Vite)
# -------------------------------------------

# Supabase (used for news, guides, support tickets)
VITE_SUPABASE_URL=https://hlgoqcbokifrcksvqjzj.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhsZ29xY2Jva2lmcmNrc3ZxanpqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4OTU4ODMsImV4cCI6MjA4NzQ3MTg4M30.3yk7qqyLQjvHvdnvUe-zOBfslro6Ryuhm5QzXH-N9i8

# Backend API URL (enables MuOnline SQL Server mode)
# Leave empty to use Supabase-only mode
VITE_API_URL=http://104.234.119.204:3001

# -------------------------------------------
# Backend - Server
# -------------------------------------------

NODE_ENV=development
PORT=3001

# -------------------------------------------
# Backend - SQL Server Connection
# -------------------------------------------

DB_SERVER=104.234.119.204
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=98*@msd8wdva1
DB_DATABASE=MuOnlineS4
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# -------------------------------------------
# Backend - Multi-Database Names
# -------------------------------------------
# These match the GxNewWeb multi-DB pattern.
# If your server uses a single database for everything,
# set all three to the same name as DB_DATABASE.

# Game database (Character, Guild, GuildMember, MuCastle_DATA)
DB_GAME=MuOnlineS4

# Account database (MEMB_INFO, MEMB_STAT, AccountCharacter)
DB_ACCOUNT=MuOnlineS4

# Web database (DmN_Shop_Credits, DmN_Vip_Users, DmN_User_Salts, etc.)
DB_WEB=dmncms

# -------------------------------------------
# Backend - Authentication (JWT)
# -------------------------------------------

JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=24h

# -------------------------------------------
# Backend - Password Mode
# -------------------------------------------
# Matches GxNewWeb MD5 modes:
#   0 = Plain text (password stored as-is)
#   1 = SQL Server stored procedure (DmN_Check_Acc_MD5)
#   2 = PHP-style MD5 hash
MD5_MODE=1

# -------------------------------------------
# Backend - Character Reset Configuration
# -------------------------------------------
# Column names in the Character table for resets
# These must match your MuOnline database schema

RESET_COLUMN=ResetCount
GRESET_COLUMN=MasterResetCount

# Minimum level required to reset
RESET_LEVEL=400

# Zen cost per reset (0 = free)
RESET_MONEY=0

# Character level after reset
LEVEL_AFTER_RESET=1

# -------------------------------------------
# Backend - Grand Reset Configuration
# -------------------------------------------

# Minimum resets required for grand reset
GRESET_RESETS_REQUIRED=10

# Zen cost per grand reset (0 = free)
GRESET_MONEY=0

# Resets after grand reset (0 = reset to 0)
GRESET_RESETS_AFTER=0

# -------------------------------------------
# Backend - Rate Limiting
# -------------------------------------------

# Time window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 200)
RATE_LIMIT_MAX=200
